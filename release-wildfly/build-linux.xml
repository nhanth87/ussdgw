<?xml version="1.0"?>
<project name="restcomm.ussdgw.release.linux" default="release" basedir=".">
    <property environment="sys"/>
    <property name="release.dir" location="${basedir}/target" />
    <property name="base.dir" location="${basedir}" />
    <property name="restcomm.ussd.dir" value="${basedir}/.." />
    <property name="m2.repo" value="${user.home}/.m2/repository" />
    <property name="restcomm.ussd.release.version" value="7.2.1-SNAPSHOT"/>

    <property name="wildfly.local.zip" value="${base.dir}/wildfly-10.0.0.Final-cleaned.zip" />
    <property name="wildfly.home.relative.path" value="wildfly-10.0.0.Final"/>
    <property name="jboss.home" value ="${release.dir}/${wildfly.home.relative.path}/"/>
    <property name="deploy.dir" value="${jboss.home}/standalone/deployments" />
    <property name="jboss.modules.path" value="${jboss.home}/modules/system/layers/base" />

    <property name="javassist.version" value="3.31.0-GA" />
    <property name="javassist.patch.jar" value="${m2.repo}/org/javassist/javassist/${javassist.version}/javassist-${javassist.version}.jar" />
    <property name="jandex.patch.jar" value="${base.dir}/jandex-2.2.3.Final.jar" />

    <property name="patched.standalone.xml" value="${base.dir}/standalone-patched.xml" />

    <property name="jss7.dir" value="${restcomm.ussd.dir}/../jSS7" />
    <property name="jain-slee.dir" value="${restcomm.ussd.dir}/../jain-slee/jain-slee" />
    <property name="jain-slee-ss7.dir" value="${restcomm.ussd.dir}/../jain-slee.ss7" />
    <property name="jain-slee-http.dir" value="${restcomm.ussd.dir}/../jain-slee-http-okhttp" />
    <property name="jain-slee-jdbc.dir" value="${restcomm.ussd.dir}/../jain-slee.jdbc" />
    <property name="jain-slee-sip.dir" value="${restcomm.ussd.dir}/../jain-slee.sip" />

    <property name="restcomm-jss7.version" value="9.2.12" />
    <property name="restcomm-map-ra.version" value="9.2.12" />
    <property name="restcomm-slee.http.version" value="7.0.0-SNAPSHOT" />
    <property name="restcomm-slee.jdbc.version" value="7.0.0-SNAPSHOT" />
    <property name="restcomm-slee.sip.version" value="7.0.0-SNAPSHOT" />

    <target name="clean">
        <delete dir="${release.dir}" failonerror="false"/>
    </target>

    <target name="extract-wildfly">
        <echo>Extracting WildFly 10 base distro</echo>
        <available file="${wildfly.local.zip}" property="wildfly.zip.exists" />
        <fail unless="wildfly.zip.exists" message="WildFly zip not found: ${wildfly.local.zip}" />
        <mkdir dir="${release.dir}" />
        <mkdir dir="${release.dir}/${wildfly.home.relative.path}" />
        <exec executable="python3" dir="${basedir}" failonerror="true">
            <arg value="extract-wildfly.py"/>
            <arg value="${wildfly.local.zip}"/>
            <arg value="${release.dir}/${wildfly.home.relative.path}"/>
        </exec>
    </target>

    <target name="patch-jandex">
        <echo>Patching Jandex</echo>
        <property name="jandex.module.dir" value="${jboss.home}/modules/system/layers/base/org/jboss/jandex/main" />
        <copy file="${jandex.patch.jar}" todir="${jandex.module.dir}" overwrite="true" failonerror="true" />
        <replace file="${jandex.module.dir}/module.xml" token="jandex-2.0.1.Final.jar" value="jandex-2.2.3.Final.jar" />
        <delete file="${jandex.module.dir}/jandex-2.0.1.Final.jar" failonerror="false" />
    </target>

    <target name="patch-javassist">
        <echo>Patching org.javassist to ${javassist.version}</echo>
        <property name="javassist.module.dir" value="${jboss.modules.path}/org/javassist/main" />
        <copy file="${javassist.patch.jar}" todir="${javassist.module.dir}" overwrite="true" failonerror="true" />
        <replace file="${javassist.module.dir}/module.xml" token="javassist-3.18.1-GA.jar" value="javassist-${javassist.version}.jar" />
        <delete file="${javassist.module.dir}/javassist-3.18.1-GA.jar" failonerror="false" />
        <copy file="${javassist.patch.jar}" todir="${jboss.home}/lib" overwrite="true" failonerror="false" />
    </target>

    <target name="copy-standalone-config">
        <echo>Copying patched standalone.xml</echo>
        <copy file="${patched.standalone.xml}" tofile="${jboss.home}/standalone/configuration/standalone.xml" overwrite="true" />
        <copy todir="${jboss.home}/standalone/configuration" overwrite="true">
            <fileset dir="${base.dir}/config-seed/configuration">
                <include name="mgmt-*.properties"/>
            </fileset>
        </copy>
        <replace file="${jboss.home}/bin/standalone.conf" token='JAVA_OPTS="$JAVA_OPTS -Djboss.server.default.config=standalone-sip.xml"' value='JAVA_OPTS="$JAVA_OPTS -Djboss.server.default.config=standalone.xml"' />
    </target>

    <target name="clean-up-distro">
        <delete includeemptydirs="true" failonerror="false">
            <fileset dir="${deploy.dir}">
                <include name="*.jar" />
                <include name="*.war" />
            </fileset>
        </delete>
    </target>

    <target name="verify-slee-jars">
        <echo>Verifying SLEE container JARs are Maven-compiled (no Eclipse stubs)</echo>
        <property name="slee.extension.jar"
                  value="${jain-slee.dir}/container/build/as7/extension/target/module/main/slee-container-build-as7-extension-8.jar"/>
        <property name="slee.modules.dir"
                  value="${jain-slee.dir}/container/build/as7/modules/target/module/main"/>
        <available file="${slee.extension.jar}" property="slee.extension.jar.exists"/>
        <fail unless="slee.extension.jar.exists"
              message="SLEE extension jar missing: ${slee.extension.jar}. Run: mvn -f ${jain-slee.dir}/container/build/as7/pom.xml clean package -Dmaven.test.skip=true"/>
        <available file="${slee.modules.dir}" type="dir" property="slee.modules.dir.exists"/>
        <fail unless="slee.modules.dir.exists"
              message="SLEE modules dir missing: ${slee.modules.dir}. Run: mvn -f ${jain-slee.dir}/container/build/as7/pom.xml clean package -Dmaven.test.skip=true"/>
        <exec executable="bash" failonerror="true">
            <arg value="-c"/>
            <arg value="if strings '${slee.extension.jar}' | grep -q 'Unresolved compilation'; then echo 'BAD JAR (Eclipse stubs): ${slee.extension.jar}' &gt;&amp;2; exit 1; fi"/>
        </exec>
        <exec executable="bash" failonerror="true">
            <arg value="-c"/>
            <arg value="for j in '${slee.modules.dir}'/*.jar; do if strings &quot;$j&quot; | grep -q 'Unresolved compilation'; then echo &quot;BAD JAR (Eclipse stubs): $j&quot; &gt;&amp;2; exit 1; fi; done"/>
        </exec>
    </target>

    <target name="copy-ussd" depends="verify-slee-jars">
        <mkdir dir="${release.dir}/extra" />

        <!-- deploy: jSS7 modules from local workspace -->
        <echo>Deploying jSS7 modules from local workspace</echo>
        <property name="jss7.modules.target" value="${jss7.dir}/service/wildfly/modules/target/module"/>
        <property name="jss7.extension.target" value="${jss7.dir}/service/wildfly/extension/target/module"/>
        <property name="jss7.commons.target" value="${jss7.dir}/service/wildfly/restcomm-ss7-wildfly-commons/target/module"/>

        <mkdir dir="${jboss.modules.path}/org/restcomm/ss7/modules/main"/>
        <copy todir="${jboss.modules.path}/org/restcomm/ss7/modules/main" overwrite="true">
            <fileset dir="${jss7.modules.target}/main">
                <include name="**/*.jar"/>
            </fileset>
        </copy>
        <copy todir="${jboss.modules.path}/org/restcomm/ss7/modules/main" overwrite="true">
            <fileset dir="${jss7.modules.target}/main">
                <include name="module.xml"/>
            </fileset>
            <filterset>
                <filter token="project.version" value="${restcomm-jss7.version}"/>
            </filterset>
        </copy>

        <mkdir dir="${jboss.modules.path}/org/restcomm/ss7/extension/main"/>
        <copy todir="${jboss.modules.path}/org/restcomm/ss7/extension/main" overwrite="true">
            <fileset dir="${jss7.extension.target}/main">
                <include name="**/*"/>
            </fileset>
        </copy>

        <mkdir dir="${jboss.modules.path}/org/restcomm/ss7/commons/main"/>
        <copy todir="${jboss.modules.path}/org/restcomm/ss7/commons/main" overwrite="true">
            <fileset dir="${jss7.commons.target}/main">
                <include name="**/*"/>
            </fileset>
        </copy>
        <copy file="${m2.repo}/javolution/javolution/5.5.1/javolution-5.5.1.jar" todir="${jboss.modules.path}/org/restcomm/ss7/commons/main" overwrite="true" />

        <!-- deploy: SIP javax.servlet.sip modules -->
        <echo>Copying SIP servlet modules</echo>
        <mkdir dir="${jboss.modules.path}/org/mobicents/javax/servlet/sip/main"/>
        <copy todir="${jboss.modules.path}/org/mobicents/javax/servlet/sip/main" overwrite="true">
            <fileset dir="${base.dir}/sip-modules/org/mobicents/javax/servlet/sip/main">
                <include name="**/*"/>
            </fileset>
        </copy>

        <!-- deploy: HTTP Servlet RA common module -->
        <echo>Copy HTTP Servlet RA common module</echo>
        <mkdir dir="${jboss.modules.path}/org/restcomm/slee/resource/http/common/main"/>
        <copy todir="${jboss.modules.path}/org/restcomm/slee/resource/http/common/main" overwrite="true">
            <fileset dir="${jain-slee-http.dir}/resources/http-servlet/common/target">
                <include name="restcomm-slee-ra-http-servlet-common.jar"/>
            </fileset>
            <fileset dir="${jain-slee-http.dir}/resources/http-servlet/common/src/main/module">
                <include name="module.xml"/>
            </fileset>
        </copy>

        <!-- deploy: SLEE container modules from local workspace -->
        <echo>Copy SLEE container modules from local workspace</echo>
        <mkdir dir="${jboss.modules.path}/org/restcomm/slee/container/lib/main" />
        <copy todir="${jboss.modules.path}/org/restcomm/slee/container/lib/main" overwrite="true">
            <fileset dir="${jain-slee.dir}/container/build/as7/modules/target/module/main">
                <include name="**" />
            </fileset>
        </copy>
        <mkdir dir="${jboss.modules.path}/org/restcomm/slee/container/extension/main" />
        <copy todir="${jboss.modules.path}/org/restcomm/slee/container/extension/main" overwrite="true">
            <fileset dir="${jain-slee.dir}/container/build/as7/extension/target/module/main">
                <include name="**" />
            </fileset>
        </copy>

        <!-- Fix WildFly 10 module name: org.hibernate.orm. -> org.hibernate -->
        <replace file="${jboss.modules.path}/org/restcomm/slee/container/lib/main/module.xml" token='        &lt;module name="org.hibernate.orm." export="true"/&gt;' value='        &lt;module name="org.hibernate" export="true"/&gt;' />

        <!-- HTTP Servlet RA + SS7 API classes visible to SLEE container / RA classloaders -->
        <replace file="${jboss.modules.path}/org/restcomm/slee/container/lib/main/module.xml" token='    &lt;/dependencies&gt;' value='        &lt;module name="org.restcomm.slee.resource.http.common" export="true"/&gt;${line.separator}        &lt;module name="org.restcomm.ss7.modules" export="true"/&gt;${line.separator}    &lt;/dependencies&gt;' />

        <!-- Alias module: org.apache.commons.pool2 -> org.apache.commons.pool -->
        <mkdir dir="${jboss.modules.path}/org/apache/commons/pool2/main"/>
        <echo file="${jboss.modules.path}/org/apache/commons/pool2/main/module.xml"><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
<module xmlns="urn:jboss:module:1.3" name="org.apache.commons.pool2">
    <dependencies>
        <module name="org.apache.commons.pool" export="true"/>
    </dependencies>
</module>]]></echo>

        <!-- Alias modules for WildFly 10 compatibility -->
        <mkdir dir="${jboss.modules.path}/org/wildfly/clustering/infinispan/main"/>
        <echo file="${jboss.modules.path}/org/wildfly/clustering/infinispan/main/module.xml"><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
<module xmlns="urn:jboss:module:1.3" name="org.wildfly.clustering.infinispan">
    <dependencies>
        <module name="org.wildfly.clustering.infinispan.spi" export="true"/>
    </dependencies>
</module>]]></echo>

        <mkdir dir="${jboss.modules.path}/org/wildfly/naming/main"/>
        <echo file="${jboss.modules.path}/org/wildfly/naming/main/module.xml"><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
<module xmlns="urn:jboss:module:1.3" name="org.wildfly.naming">
    <dependencies>
        <module name="org.jboss.as.naming" export="true"/>
    </dependencies>
</module>]]></echo>

        <mkdir dir="${jboss.modules.path}/org/wildfly/transaction/client/main"/>
        <echo file="${jboss.modules.path}/org/wildfly/transaction/client/main/module.xml"><![CDATA[<?xml version="1.0" encoding="UTF-8"?>
<module xmlns="urn:jboss:module:1.3" name="org.wildfly.transaction.client">
    <dependencies>
        <module name="org.jboss.as.transactions" export="true"/>
    </dependencies>
</module>]]></echo>

        <!-- deploy: ussd extensions -->
        <echo>Copy USSD extensions</echo>
        <mkdir dir="${jboss.modules.path}/org/mobicents/ussd/bootstrap/main" />
        <copy todir="${jboss.modules.path}/org/mobicents/ussd/bootstrap/main" overwrite="true">
            <fileset dir="${restcomm.ussd.dir}/core/bootstrap-wildfly/target/module/main">
                <include name="**" />
            </fileset>
        </copy>

        <!-- deploy: USSD service DU and management war -->
        <echo>Copy USSD Gateway DUs</echo>
        <copy file="${restcomm.ussd.dir}/core/slee/services-du/target/services-DU-${restcomm.ussd.release.version}.jar" todir="${deploy.dir}" failonerror="true" />
        <copy file="${restcomm.ussd.dir}/management/ussd-management/target/ussd-management.war" todir="${deploy.dir}" failonerror="true" />

        <!-- deploy: MAP RA DU from local workspace -->
        <echo>Copy RestComm MAP RA DU from local workspace</echo>
        <copy file="${jain-slee-ss7.dir}/resources/map/du/target/restcomm-slee-ra-map-du-${restcomm-map-ra.version}.jar" todir="${deploy.dir}" failonerror="true" />

        <!-- deploy: SIP11 RA DU from local workspace -->
        <echo>Copy RestComm SIP11 RA DU from local workspace</echo>
        <copy file="${jain-slee-sip.dir}/resources/sip11/du/target/sip11-ra-DU-${restcomm-slee.sip.version}.jar" todir="${deploy.dir}" failonerror="true" />

        <!-- deploy: HTTP Client RA DU from Maven local repo -->
        <echo>Copy RestComm HTTP Client RA DU from local .m2</echo>
        <copy file="${m2.repo}/org/mobicents/resources/http-client-ra-DU/${restcomm-slee.http.version}/http-client-ra-DU-${restcomm-slee.http.version}.jar" todir="${deploy.dir}" failonerror="true" />

        <!-- deploy: HTTP Servlet RA DU (prefer local workspace build) -->
        <echo>Copy RestComm HTTP Servlet RA DU</echo>
        <copy todir="${deploy.dir}" failonerror="false" flatten="true">
            <fileset dir="${jain-slee-http.dir}/resources/http-servlet/du/target">
                <include name="http-servlet-ra-DU-*.jar"/>
                <include name="restcomm-slee-ra-http-servlet-DU-*.jar"/>
            </fileset>
            <mapper type="glob" from="*" to="http-servlet-ra-DU-${restcomm-slee.http.version}.jar"/>
        </copy>
        <available file="${deploy.dir}/http-servlet-ra-DU-${restcomm-slee.http.version}.jar" property="http.servlet.du.exists"/>
        <copy file="${m2.repo}/org/mobicents/resources/http-servlet-ra-DU/${restcomm-slee.http.version}/http-servlet-ra-DU-${restcomm-slee.http.version}.jar"
              todir="${deploy.dir}"
              failonerror="false"/>
        <available file="${deploy.dir}/http-servlet-ra-DU-${restcomm-slee.http.version}.jar" property="http.servlet.du.exists"/>
        <fail unless="http.servlet.du.exists"
              message="HTTP Servlet RA DU missing. Build: mvn -f ${jain-slee-http.dir}/resources/http-servlet/pom.xml clean install -Dmaven.test.skip=true"/>

        <!-- deploy: JDBC RA DU from Maven local repo -->
        <echo>Copy RestComm JDBC RA DU from local .m2</echo>
        <copy file="${m2.repo}/org/restcomm/resources/restcomm-slee-ra-jdbc-DU/${restcomm-slee.jdbc.version}/restcomm-slee-ra-jdbc-DU-${restcomm-slee.jdbc.version}.jar" todir="${deploy.dir}" failonerror="true" />

        <!-- deploy: jSS7 OAM UI from local workspace -->
        <copy todir="${deploy.dir}" failonerror="true">
            <fileset dir="${jss7.dir}/oam/new-ui/target">
                <include name="*.war" />
            </fileset>
        </copy>

        <!-- tools: jSS7 simulator from local workspace -->
        <copy todir="${release.dir}/tools/restcomm-jss7-simulator" failonerror="true">
            <fileset dir="${jss7.dir}/tools/simulator/bootstrap/target/simulator-ss7">
                <include name="**" />
            </fileset>
        </copy>
        <copy file="${restcomm.ussd.dir}/core/bootstrap/src/main/config/ss7-simulator/main_simulator2.xml" todir="${release.dir}/tools/restcomm-jss7-simulator/data" failonerror="true" />
        <copy file="${restcomm.ussd.dir}/core/bootstrap/src/main/config/ss7-simulator/win_simulator2.xml" todir="${release.dir}/tools/restcomm-jss7-simulator/data" failonerror="true" />

        <!-- tools: USSD simulator -->
        <copy todir="${release.dir}/tools/restcomm-ussd-simulator" failonerror="true">
            <fileset dir="${restcomm.ussd.dir}/test/bootstrap/target/ussd-server">
                <include name="**" />
            </fileset>
        </copy>

        <!-- CLI: USSD CLI and jSS7 shell -->
        <copy file="${restcomm.ussd.dir}/core/oam/cli/target/ussd-cli-${restcomm.ussd.release.version}.jar" todir="${jboss.home}/lib" failonerror="true" />
        <copy todir="${release.dir}/tools/restcomm-ss7-shell" failonerror="true">
            <fileset dir="${jss7.dir}/management/shell-client/target/restcomm-cli">
                <include name="**" />
            </fileset>
        </copy>

        <!-- Copy default sample SS7/USSD config data to standalone/data for first-startup -->
        <mkdir dir="${jboss.home}/standalone/data" />
        <copy todir="${jboss.home}/standalone/data" failonerror="false">
            <fileset dir="${restcomm.ussd.dir}/core/bootstrap/src/main/config/data">
                <include name="*.xml" />
            </fileset>
        </copy>

        <!-- Copy ussdhttpdemo.war to standalone BEFORE cloning to simulator -->
        <echo>Copy ussdhttpdemo.war to standalone deployments</echo>
        <copy file="${restcomm.ussd.dir}/examples/http/target/ussdhttpdemo.war" todir="${jboss.home}/standalone/deployments" failonerror="true" />

        <!-- Copy restcomm.war to standalone BEFORE cloning to simulator -->
        <echo>Copy restcomm.war to standalone deployments</echo>
        <copy file="${jain-slee-http.dir}/resources/http-servlet/war/target/restcomm.war" todir="${jboss.home}/standalone/deployments" failonerror="true" />

        <!-- prepare simulator profile - clone standalone (now includes both wars) -->
        <mkdir dir="${jboss.home}/simulator" />
        <copy todir="${jboss.home}/simulator" failonerror="true">
            <fileset dir="${jboss.home}/standalone">
                <include name="**" />
            </fileset>
        </copy>

        <!-- Data config for simulator -->
        <mkdir dir="${jboss.home}/simulator/data" />
        <copy todir="${jboss.home}/simulator/data" failonerror="false">
            <fileset dir="${restcomm.ussd.dir}/core/bootstrap/src/main/config/data">
                <include name="*.xml" />
            </fileset>
        </copy>
    </target>

    <target name="make-final-zip">
        <echo>Creating final release ZIP</echo>
        <zip destfile="${base.dir}/restcomm-ussd-${restcomm.ussd.release.version}-linux.zip" filesonly="false">
            <zipfileset dir="${release.dir}" prefix="restcomm-ussd-${restcomm.ussd.release.version}">
                <include name="**" />
            </zipfileset>
        </zip>
    </target>

    <target name="release" depends="clean,extract-wildfly,patch-jandex,patch-javassist,copy-standalone-config,clean-up-distro,copy-ussd,make-final-zip" />
</project>
