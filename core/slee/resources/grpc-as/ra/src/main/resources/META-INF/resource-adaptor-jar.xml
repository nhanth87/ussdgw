<?xml version="1.0" encoding="ISO-8859-1"?>
<!DOCTYPE resource-adaptor-jar PUBLIC "-//Sun Microsystems, Inc.//DTD JAIN SLEE Resource Adaptor 1.1//EN" "http://java.sun.com/dtd/slee-resource-adaptor-jar_1_1.dtd">

<resource-adaptor-jar>

    <resource-adaptor ignore-ra-type-event-type-check="True">

        <resource-adaptor-name>GrpcAsResourceAdaptor</resource-adaptor-name>
        <resource-adaptor-vendor>org.mobicents.ussd</resource-adaptor-vendor>
        <resource-adaptor-version>1.0</resource-adaptor-version>

        <resource-adaptor-type-ref>
            <resource-adaptor-type-name>GrpcAsResourceAdaptorType</resource-adaptor-type-name>
            <resource-adaptor-type-vendor>org.mobicents.ussd</resource-adaptor-type-vendor>
            <resource-adaptor-type-version>1.0</resource-adaptor-type-version>
        </resource-adaptor-type-ref>

        <event-type-ref>
            <event-type-name>ussd.grpc.events.PUSH_RECEIVED</event-type-name>
            <event-type-vendor>org.mobicents.ussd</event-type-vendor>
            <event-type-version>1.0</event-type-version>
        </event-type-ref>

        <resource-adaptor-classes>
            <resource-adaptor-class>
                <resource-adaptor-class-name>
                    org.mobicents.ussd.grpc.ra.GrpcAsResourceAdaptor
                </resource-adaptor-class-name>
            </resource-adaptor-class>
        </resource-adaptor-classes>

        <config-property>
            <config-property-name>GRPC_DEADLINE_MS</config-property-name>
            <config-property-type>java.lang.Long</config-property-type>
            <config-property-value>30000</config-property-value>
        </config-property>

        <!-- GRPC-2: Enable TLS on the gRPC client channels to the Application Server. -->
        <config-property>
            <config-property-name>GRPC_USE_SSL</config-property-name>
            <config-property-type>java.lang.Boolean</config-property-type>
            <config-property-value>false</config-property-value>
        </config-property>
        <!-- Optional JKS trust-store path. Empty = use JVM default trust store (cacerts). -->
        <config-property>
            <config-property-name>GRPC_SSL_TRUST_STORE</config-property-name>
            <config-property-type>java.lang.String</config-property-type>
            <config-property-value></config-property-value>
        </config-property>

        <!-- GRPC-3: PEM cert chain for the gRPC push server (gateway as gRPC server). -->
        <config-property>
            <config-property-name>GRPC_PUSH_SSL_CERT_CHAIN</config-property-name>
            <config-property-type>java.lang.String</config-property-type>
            <config-property-value></config-property-value>
        </config-property>
        <!-- PEM private key matching GRPC_PUSH_SSL_CERT_CHAIN. -->
        <config-property>
            <config-property-name>GRPC_PUSH_SSL_PRIVATE_KEY</config-property-name>
            <config-property-type>java.lang.String</config-property-type>
            <config-property-value></config-property-value>
        </config-property>

    </resource-adaptor>

</resource-adaptor-jar>
