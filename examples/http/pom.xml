	<build>
		<finalName>ussdhttpdemo</finalName>
		<plugins>
				<plugin>
					<groupId>org.apache.maven.plugins</groupId>
					<artifactId>maven-war-plugin</artifactId>
					<configuration>
						<packagingExcludes>WEB-INF/lib/*/module-info.class,WEB-INF/lib/*/META-INF/versions/*/module-info.class</packagingExcludes>
					</configuration>
				</plugin>
			<plugin>
				<artifactId>maven-antrun-plugin</artifactId>
				<executions>
					<execution>
						<id>fix-activation-classpath</id>
						<phase>package</phase>
						<goals>
							<goal>run</goal>
						</goals>
						<configuration>
							<target>
								<!-- mail-1.4.jar manifest references activation.jar via Class-Path -->
								<!-- Copy activation-1.1.jar to activation.jar to satisfy the reference -->
								<unzip overwrite="true" src="target/${project.build.finalName}.war" dest="target/war-fix" />
								<copy file="target/war-fix/WEB-INF/lib/activation-1.1.jar" tofile="target/war-fix/WEB-INF/lib/activation.jar" />
								<!-- Strip module-info.class from dependency JARs to prevent WildFly 10 indexing warnings (WFLYSRV0003) using pure Ant/Java -->
								<echo message="Stripping module-info.class from dependency JARs..."/>
								<mkdir dir="target/build-tools"/>
								<echo file="target/build-tools/StripModuleInfo.java">import java.io.*;
import java.util.zip.*;
public class StripModuleInfo {
    public static void main(String[] args) throws Exception {
        System.out.println("Stripping module-info.class from JARs in: " + args[0]);
        File libDir = new File(args[0]);
        File[] files = libDir.listFiles();
        if (files == null) return;
        for (File jar : files) {
            if (!jar.getName().endsWith(".jar")) continue;
            File tmp = new File(jar.getAbsolutePath() + ".tmp");
            try (FileInputStream fis = new FileInputStream(jar);
                 ZipInputStream zis = new ZipInputStream(fis);
                 FileOutputStream fos = new FileOutputStream(tmp);
                 ZipOutputStream zos = new ZipOutputStream(fos)) {
                ZipEntry entry;
                while ((entry = zis.getNextEntry()) != null) {
                    String name = entry.getName();
                    if (name.equals("module-info.class") || name.contains("/module-info.class")) continue;
                    zos.putNextEntry(entry);
                    byte[] buf = new byte[4096];
                    int read;
                    while ((read = zis.read(buf)) != -1) zos.write(buf, 0, read);
                    zos.closeEntry();
                }
            }
            if (!jar.delete()) {
                System.err.println("Failed to delete: " + jar.getAbsolutePath());
                tmp.delete();
                continue;
            }
            if (!tmp.renameTo(jar)) {
                System.err.println("Failed to rename: " + tmp.getAbsolutePath());
            } else {
                System.out.println("Stripped: " + jar.getName());
            }
        }
        System.out.println("Done stripping module-info.class");
    }
}
</echo>
								<javac srcdir="target/build-tools" destdir="target/build-tools"/>
								<java classname="StripModuleInfo" classpath="target/build-tools" fork="true" failonerror="true">
									<arg value="target/war-fix/WEB-INF/lib"/>
								</java>
								<delete dir="target/build-tools"/>
								<zip basedir="target/war-fix" destfile="target/${project.build.finalName}.war" />
								<sleep milliseconds="500"/>
								<delete dir="target/war-fix" failonerror="false"/>
							</target>
						</configuration>
					</execution>
					<execution>
						<id>prepare-jboss-jar</id>
						<phase>package</phase>
						<goals>
							<goal>run</goal>
						</goals>
						<configuration>
							<target>
								<unzip overwrite="true" src="target/${project.build.finalName}.war" dest="target/jboss-pack" />
								<replace file="target/jboss-pack/WEB-INF/jboss-web.xml"
									value=""
									token="&lt;!-- class-loading insertion" />
								<replace file="target/jboss-pack/WEB-INF/jboss-web.xml"
									value=""
									token="class-loading insertion --&gt;" />
								<zip basedir="target/jboss-pack" destfile="target/ussdhttpdemo-jboss.war" />
							</target>
						</configuration>
					</execution>
				</executions>
			</plugin>
		</plugins>
	</build>

	<profiles>
		<profile>
			<!-- Adds the files to JBoss AS -->
			<id>deploy-examples-jboss5</id>
			<build>
				<plugins>
					<plugin>
						<artifactId>maven-antrun-plugin</artifactId>
						<executions>
							<execution>
								<id>deploy</id>
								<phase>install</phase>
								<goals>
									<goal>run</goal>
								</goals>
								<configuration>
									<target>
										<echo>
											${jboss.home}server/default/deploy
										</echo>
										<copy file="${project.build.directory}/ussdhttpdemo-jboss.war" todir="${jboss.home}/server/${node}/deploy" />
									</target>
								</configuration>
							</execution>
							<execution>
								<id>undeploy</id>
								<phase>clean</phase>
								<goals>
									<goal>run</goal>
								</goals>
								<configuration>
									<target>
										<delete file="${jboss.home}/server/${node}/deploy/ussdhttpdemo-jboss.war" failonerror="false">
										</delete>
									</target>
								</configuration>
							</execution>
						</executions>
					</plugin>
				</plugins>
			</build>
		</profile>

		<profile>
			<!-- Adds the files to WildFly server -->
