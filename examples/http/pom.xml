										</echo>
										<copy file="${project.build.directory}/ussdhttpdemo.war" todir="${jboss.home}/standalone/deployments" />
									</target>
								</configuration>
							</execution>
							<execution>
								<id>undeploy</id>
								<phase>clean</phase>
								<goals>
									<goal>run</goal>
								</goals>
								<configuration>
									<target>
										<delete file="${jboss.home}/standalone/deployments/ussdhttpdemo.war" failonerror="false">
										</delete>
									</target>
								</configuration>
							</execution>
						</executions>
					</plugin>
